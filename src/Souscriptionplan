export default function SubscriptionPlans({ onBack, onSelectPlan, currentPlan = 'gratuit' }) {
  const [selected, setSelected] = useState(null);
  const [showConfirm, setShowConfirm] = useState(false);
  const [activePlan, setActivePlan] = useState(currentPlan);
  const [paymentMethod, setPaymentMethod] = useState('mtn');

  const handleSelect = (plan) => {
    if (plan.id === activePlan) return;
    setSelected(plan);
    setShowConfirm(true);
  };

  const handleConfirm = () => {
    setActivePlan(selected.id);
    setShowConfirm(false);
    setSelected(null);
    if (onSelectPlan) onSelectPlan(selected);
  };

  return (
    <div style={styles.wrapper}>

      {/* Modal de confirmation paiement */}
      {showConfirm && selected && (
        <div style={styles.overlay}>
          <div style={styles.confirmModal}>
            <button style={styles.closeModal} onClick={() => setShowConfirm(false)}>
              <X size={20} />
            </button>
            <h3 style={styles.confirmTitle}>Confirmer l'abonnement</h3>
            <div style={{ ...styles.planBadge, backgroundColor: selected.bgColor, borderColor: selected.borderColor }}>
              {selected.icon}
              <div>
                <p style={{ ...styles.planBadgeName, color: selected.color }}>{selected.name}</p>
                <p style={styles.planBadgePrice}>{selected.price.toLocaleString()} FCFA / mois</p>
              </div>
            </div>

            <p style={styles.confirmText}>Choisissez votre mode de paiement :</p>

            <div style={styles.paymentOptions}>
              {[
                { id: 'mtn', label: 'MTN Mobile Money', icon: '📱' },
                { id: 'orange', label: 'Orange Money', icon: '🟠' },
              ].map(pm => (
                <div
                  key={pm.id}
                  style={{
                    ...styles.paymentOption,
                    borderColor: paymentMethod === pm.id ? selected.color : '#dee2e6',
                    backgroundColor: paymentMethod === pm.id ? selected.bgColor : '#ffffff',
                  }}
                  onClick={() => setPaymentMethod(pm.id)}
                >
                  <span style={styles.pmIcon}>{pm.icon}</span>
                  <span style={styles.pmLabel}>{pm.label}</span>
                  {paymentMethod === pm.id && <Check size={16} color={selected.color} />}
                </div>
              ))}
            </div>

            <div style={styles.confirmTotal}>
              <span>Total à payer</span>
              <span style={{ color: selected.color, fontWeight: '900', fontSize: '20px' }}>
                {selected.price.toLocaleString()} FCFA
              </span>
            </div>

            <button
              style={{ ...styles.confirmBtn, backgroundColor: selected.color }}
              onClick={handleConfirm}
            >
              ✅ Confirmer et payer
            </button>
            <button style={styles.cancelConfirmBtn} onClick={() => setShowConfirm(false)}>
              Annuler
            </button>
          </div>
        </div>
      )}

      <div style={styles.container}>

        {/* Header */}
        <div style={styles.header}>
          {onBack && (
            <button style={styles.backBtn} onClick={onBack}>
              <ArrowLeft size={18} /> Retour
            </button>
          )}
          <h1 style={styles.title}>Choisissez votre plan</h1>
          <p style={styles.subtitle}>
            Boostez la visibilité de vos produits et augmentez vos ventes
          </p>

          {/* Plan actuel */}
          <div style={styles.currentPlanBadge}>
            Votre plan actuel : <strong>{plans.find(p => p.id === activePlan)?.name || 'Gratuit'}</strong>
          </div>
        </div>

        {/* Grille des plans */}
        <div style={styles.plansGrid}>
          {plans.map((plan) => {
            const isActive = activePlan === plan.id;
            const isRecommended = plan.id === 'premium';
            return (
              <div
                key={plan.id}
                style={{
                  ...styles.planCard,
                  borderColor: isActive ? plan.color : isRecommended ? plan.color : '#e9ecef',
                  borderWidth: isActive || isRecommended ? '2px' : '1px',
                  transform: isRecommended ? 'scale(1.03)' : 'scale(1)',
                  boxShadow: isRecommended ? `0 20px 40px ${plan.color}22` : '0 8px 24px rgba(0,0,0,0.04)',
                }}
              >
                {/* Badge */}
                {plan.badge && (
                  <div style={{ ...styles.badge, backgroundColor: plan.color }}>
                    {plan.badge}
                  </div>
                )}

                {isActive && (
                  <div style={{ ...styles.badge, backgroundColor: '#2d6a4f', right: '16px', left: 'auto' }}>
                    ✅ Actif
                  </div>
                )}

                <div style={{ ...styles.planIconWrap, backgroundColor: plan.bgColor }}>
                  {plan.icon}
                </div>

                <h3 style={{ ...styles.planName, color: plan.color }}>{plan.name}</h3>

                <div style={styles.priceWrap}>
                  {plan.price === 0 ? (
                    <span style={{ ...styles.planPrice, color: plan.color }}>Gratuit</span>
                  ) : (
                    <>
                      <span style={{ ...styles.planPrice, color: plan.color }}>
                        {plan.price.toLocaleString()}
                      </span>
                      <span style={styles.pricePeriod}> FCFA / mois</span>
                    </>
                  )}
                </div>

                {plan.produitsMisEnAvant > 0 && (
                  <div style={{ ...styles.highlightBox, backgroundColor: plan.bgColor, borderColor: plan.borderColor }}>
                    <Star size={14} color={plan.color} />
                    <span style={{ color: plan.color, fontWeight: '700', fontSize: '13px' }}>
                      {plan.produitsMisEnAvant === 999
                        ? 'Tous les produits mis en avant'
                        : `${plan.produitsMisEnAvant} produits mis en avant`}
                    </span>
                  </div>
                )}

                {/* Features */}
                <div style={styles.featureList}>
                  {plan.features.map((f, i) => (
                    <div key={i} style={styles.featureItem}>
                      <Check size={14} color={plan.color} />
                      <span style={styles.featureText}>{f}</span>
                    </div>
                  ))}
                  {plan.notIncluded.map((f, i) => (
                    <div key={i} style={styles.featureItem}>
                      <X size={14} color="#adb5bd" />
                      <span style={{ ...styles.featureText, color: '#adb5bd', textDecoration: 'line-through' }}>{f}</span>
                    </div>
                  ))}
                </div>

                <button
                  style={{
                    ...styles.selectBtn,
                    backgroundColor: isActive ? '#e9ecef' : plan.color,
                    color: isActive ? '#6c757d' : '#ffffff',
                    cursor: isActive ? 'default' : 'pointer',
                  }}
                  onClick={() => handleSelect(plan)}
                  disabled={isActive}
                >
                  {isActive ? '✅ Plan actuel' : `Choisir ${plan.name}`}
                </button>
              </div>
            );
          })}
        </div>

        {/* Section comparaison */}
        <div style={styles.compareSection}>
          <h2 style={styles.compareTitle}>Comment les produits sponsorisés sont affichés ?</h2>
          <div style={styles.compareGrid}>
            <div style={styles.compareCard}>
              <div style={styles.compareBadge} >⭐ Sponsorisé</div>
              <div style={styles.compareImg}>🍌</div>
              <p style={styles.compareText}>Banane Fraîche</p>
              <p style={styles.comparePrice}>2 500 FCFA</p>
            </div>
            <div style={styles.compareCard}>
              <div style={{ ...styles.compareBadge, backgroundColor: '#e07a5f' }}>🔥 Premium</div>
              <div style={styles.compareImg}>🍅</div>
              <p style={styles.compareText}>Tomate Bio</p>
              <p style={styles.comparePrice}>1 500 FCFA</p>
            </div>
            <div style={styles.compareCard}>
              <div style={{ ...styles.compareBadge, backgroundColor: '#f5b041' }}>👑 Gold</div>
              <div style={styles.compareImg}>🥕</div>
              <p style={styles.compareText}>Carotte Bio</p>
              <p style={styles.comparePrice}>800 FCFA</p>
            </div>
            <div style={{ ...styles.compareCard, opacity: 0.5 }}>
              <div style={styles.compareImg}>🌽</div>
              <p style={styles.compareText}>Maïs</p>
              <p style={styles.comparePrice}>3 000 FCFA</p>
              <p style={styles.compareNormal}>Position normale</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  );
}

